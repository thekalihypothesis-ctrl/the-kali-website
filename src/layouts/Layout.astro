---
import SiteNav from "../components/shared/SiteNav.astro";
import "../styles/global.css";
import "../styles/navigation.css";

interface Props {
  title?: string;
}

const { title = "Kali Hypothesis" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <SiteNav />
    <slot />
  </body>
</html>